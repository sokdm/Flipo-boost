{
  "name": "filpo-boost",
  "version": "1.0.0",
  "description": "Filpo Boost - Social Media Automation Platform",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm run build",
    "install-deps": "npm install && cd server && npm install && cd ../client && npm install",
    "render-build": "./render-build.sh"
  },
  "keywords": ["social-media", "automation", "boost", "engagement"],
  "author": "Filpo Boost",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
